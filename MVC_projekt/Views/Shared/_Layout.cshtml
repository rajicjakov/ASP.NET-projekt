<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVC_projekt</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_projekt.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MVC_projekt</a>
                <ul class="nav-links">
                    <li>
                        <a class="nav-button" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li>
                        <a class="nav-button" asp-area="" asp-controller="Login" asp-action="Login">Login</a>
                    </li>
                    <li>
                        <a class="nav-button" asp-area="" asp-controller="Editor" asp-action="Create">Create</a>
                    </li>
                    <li>
                        <a class="nav-button" asp-area="" asp-controller="Browse" asp-action="Browse">Browse</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>
    <div class="main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <footer class="footer">
        <div class="footer-container">
            &copy; 2026 - MVC_projekt - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
