@{
    ViewData["Title"] = "Welcome";
}

<section>
    <div class="welcome-card">
        <h1>Welcome to Your Music Tab Archive</h1>
        <p>This site helps you manage and explore guitar tablature, add new tabs, and browse shared arrangements.</p>
        <div class="welcome-grid">
            <div class="welcome-column">
                <h2>What you can do</h2>
                <ul>
                    <li>Browse available tablature and song arrangements</li>
                    <li>Create new tabs and organize measures</li>
                    <li>Save favorite progressions and notation</li>
                </ul>
            </div>
            <div class="welcome-column">
                <h2>Get started</h2>
                <p>Use the navigation links to log in, create your first tab, or discover what other users have shared.</p>
            </div>
        </div>
    </div>
</section>
